# Shared
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meeting_assistant
PORT=3000
BODY_SIZE_LIMIT=250mb
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# JWT
JWT_SECRET=change_me_jwt_secret
REFRESH_SECRET=change_me_refresh_secret

# Social Login
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
FRONTEND_SUCCESS_LOGIN_REDIRECT=http://localhost:3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000

# AI Provider
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_TRANSCRIPTION_CHUNK_SECONDS=900
OPENAI_TRANSCRIPTION_MODEL_MAX_SECONDS=1400
OPENAI_SUMMARY_MODEL=gpt-4o
OPENAI_LANGUAGE_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_SUMMARY_MODEL=deepseek-chat
